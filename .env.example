# Google Drive — service account JSON key (base64 encoded or raw JSON)
# Used to pull photos/videos from your Google Drive folders
GOOGLE_DRIVE_SERVICE_ACCOUNT_KEY=

# Substack RSS feed URL — powers the /blog page
# Example: https://yourname.substack.com/feed
NEXT_PUBLIC_SUBSTACK_FEED_URL=

# Formspree form ID — powers the /contact form
# Get one at https://formspree.io — replace YOUR_FORM_ID in contact/page.tsx
FORMSPREE_FORM_ID=
